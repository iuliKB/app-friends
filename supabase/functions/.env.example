# These are set as Supabase Edge Function secrets, NOT in a .env file.
# Run: supabase secrets set KEY=value
#
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are auto-injected by Supabase
# when running Edge Functions — you only need to set EXPO_ACCESS_TOKEN.

# Expo push notifications — get this from https://expo.dev/accounts/[you]/settings/access-tokens
EXPO_ACCESS_TOKEN=your-expo-access-token
