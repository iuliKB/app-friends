# Project-level npm configuration.
#
# node-options: preloads the React Native mock stub so that
# `npx tsx tests/unit/*.test.ts` commands can require component files that
# transitively import react-native (which uses Flow syntax incompatible with
# tsx/esbuild in Node.js unit-test contexts).
#
# The preload only intercepts react-native, expo-*, and @supabase/* imports
# and redirects them to minimal stubs; it does not affect Metro bundler or
# ESLint which use their own module resolvers.
node-options=--require ./tests/unit/rn-mock-preload.js
